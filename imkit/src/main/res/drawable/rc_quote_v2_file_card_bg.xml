<?xml version="1.0" encoding="utf-8"?>
<!--
    Quote V2 文件预览卡片背景：白底 + 0.5dp 边框 + 6dp 圆角。
    对标 iOS RCReferencedContentView 的 file preview card。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/rc_file_quote_card_background" />
    <stroke
        android:width="@dimen/rc_quote_v2_file_card_border"
        android:color="@color/rc_file_quote_card_border" />
    <corners android:radius="@dimen/rc_quote_v2_file_card_radius" />
</shape>
