<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rc_lively_reaction_picker_bg"
    android:paddingBottom="12dp">

    <!-- Title bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/rc_tv_detail_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="@string/rc_reaction_detail_title"
            style="@style/TextStyle.Alignment"
            android:textColor="?attr/rc_text_primary_color"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/rc_iv_detail_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/rc_close"
            android:contentDescription="@null" />
    </RelativeLayout>

    <!-- Tabs -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_rv_reaction_tabs"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:clipToPadding="false" />

    <!-- User list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_rv_reaction_users"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />
</LinearLayout>
