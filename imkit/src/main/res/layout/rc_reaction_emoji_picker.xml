<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rc_reaction_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/rc_reaction_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/rc_lively_reaction_picker_bg"
        android:paddingBottom="12dp">

        <!-- Drag area (larger grab zone) -->
        <FrameLayout
            android:id="@+id/rc_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="28dp">

            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="@drawable/rc_lively_reaction_drag_handle_bg" />
        </FrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rc_rv_emoji"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:overScrollMode="never" />
    </LinearLayout>
</FrameLayout>
