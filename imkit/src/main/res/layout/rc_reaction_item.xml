<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="20dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/rc_reaction_item_bg">

    <TextView
        android:id="@+id/rc_tv_reaction_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/TextStyle.Alignment"
        android:textColor="?attr/rc_text_primary_color"
        android:textSize="14sp" />

    <View
        android:id="@+id/rc_reaction_divider"
        android:layout_width="1dp"
        android:layout_height="12dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="?attr/rc_reaction_divider_color" />

    <TextView
        android:id="@+id/rc_tv_reaction_count"
        android:layout_width="wrap_content"
        style="@style/TextStyle.Alignment"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:maxWidth="180dp"
        android:singleLine="true"
        android:ellipsize="end"
        android:textColor="?attr/rc_text_secondary_color"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/rc_tv_reaction_overflow_count"
        android:layout_width="wrap_content"
        style="@style/TextStyle.Alignment"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textColor="?attr/rc_text_secondary_color"
        android:textSize="14sp"
        android:visibility="gone" />
</LinearLayout>
